# macOS
.DS_Store

# Scanned page images (large, copyrighted). Book folders are folders of images,
# so ignoring the images keeps every book folder out of the repo while staying
# robust to swapping books in and out. entire/ and .claude/ config are NOT
# ignored, so they track per the darthzen sync policy.
*.jpg
*.jpeg
*.png
*.tif
*.tiff
*.webp
*.bmp
